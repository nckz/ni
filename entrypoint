#!/bin/bash

# Neovim looks in $XDG_CONFIG_HOME/nvim (defaults to ~/.config/nvim). The
# Dockerfile installs the config at /.config/nvim so both an unprivileged
# user (HOME=/) and root (HOME=/root, symlinked) pick it up.

# When `ni` runs the container with --user $(id -u):$(id -g), the mapped
# user has no entry in /etc/passwd; HOME stays as / which the user can't
# write to, so nvim spams E739/E886 trying to create ShaDa state files.
# Point the XDG state/data/cache dirs at /tmp (world-writable) so nvim has
# somewhere to scribble. The config dir is fine where it is.
export XDG_DATA_HOME=/tmp/.local/share
export XDG_STATE_HOME=/tmp/.local/state
export XDG_CACHE_HOME=/tmp/.cache
mkdir -p "$XDG_DATA_HOME" "$XDG_STATE_HOME" "$XDG_CACHE_HOME"

# volume mounted working directory
VIMWD=/vimwd

# move to the working directory
cd ${VIMWD}

# start neovim with all args passed to docker
nvim $@
