#!/bin/bash
# Author: Nick Zwart
# Date: 2022jan25 (updated for neovim 2026)
# Brief: install the neovim config (init.vim + custom plugins from vim/)
#        into ~/.config/nvim, fetch the modern plugin stack (Telescope,
#        nvim-lint, conform.nvim), drop in the gitconfig, and link
#        /usr/bin/ni -> nvim.

######################################################################## STRICT
set -euo pipefail
IFS=$'\n\t'


########################################################################### CLI
BKGND_COLOR=${1:-dark}


########################################################################## MAIN
CONF_DIR="$HOME/.config/nvim"
mkdir -p "$CONF_DIR"

# Custom plugin/runtime bits live under vim/ in this repo; copy them into
# the nvim config tree (colors, plugin, autoload, ftplugin, snippets).
for sub in colors plugin autoload ftplugin snippets; do
    if [ -d "vim/$sub" ]; then
        cp -rv "vim/$sub" "$CONF_DIR/$sub"
    fi
done

cp -v gitconfig "$HOME/.gitconfig"

# write init.vim with the background swapped per first arg
sed "s/^set\ background.*/set\ background=${BKGND_COLOR}/g" < init.vim > "$CONF_DIR/init.vim"

# install plugins via neovim's native pack mechanism
mkdir -p "$CONF_DIR/pack/git-plugins/start"
git clone --depth 1 https://github.com/nvim-telescope/telescope.nvim.git \
    "$CONF_DIR/pack/git-plugins/start/telescope.nvim"
git clone --depth 1 https://github.com/nvim-lua/plenary.nvim.git \
    "$CONF_DIR/pack/git-plugins/start/plenary.nvim"
git clone --depth 1 https://github.com/mfussenegger/nvim-lint.git \
    "$CONF_DIR/pack/git-plugins/start/nvim-lint"
git clone --depth 1 https://github.com/stevearc/conform.nvim.git \
    "$CONF_DIR/pack/git-plugins/start/conform.nvim"

# make a ni executable link to nvim
ln -s "$(command -v nvim)" /usr/bin/ni
